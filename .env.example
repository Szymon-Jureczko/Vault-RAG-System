# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All inference is LOCAL — no cloud API keys required.

# ── Ollama ────────────────────────────────────────────────────────────────────
# Service name resolves inside the devcontainer compose network.
OLLAMA_BASE_URL=http://ollama:11434

# Model used during development (smaller / faster on i5 + 16 GB):
OLLAMA_MODEL_DEV=llama3.2:3b
# Model used during evaluation / production runs:
OLLAMA_MODEL_EVAL=llama3.2:8b

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=/workspace/data/chroma

# ── State DB (SQLite) ────────────────────────────────────────────────────────
STATE_DB_PATH=/workspace/data/state.db

# ── Concurrency ──────────────────────────────────────────────────────────────
# Max workers for ProcessPoolExecutor — matches i5-1135G7 logical core count.
MAX_WORKERS=8

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
