{
  "name": "RAG System",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        // Python
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.flake8",
        // Env files
        "mikestead.dotenv",
        // Git
        "eamodio.gitlens",
        // YAML / TOML
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        // REST client for testing endpoints and Ollama API
        "humao.rest-client",
        // SQLite viewer for state_db inspection
        "qwtel.sqlite-viewer"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "isort.args": [
          "--profile",
          "black"
        ],
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [
    8000, // FastAPI app server
    11434 // Ollama API
  ],
  "portsAttributes": {
    "8000": {
      "label": "App Server"
    },
    "11434": {
      "label": "Ollama"
    }
  },
  // Install Python deps, then pull the dev model into Ollama via its REST API.
  // The pull is idempotent — safe to re-run if layers are already cached.
  "postCreateCommand": "pip install -r requirements-dev.txt && curl -sf http://ollama:11434/api/pull -d '{\"name\":\"llama3.2:3b\"}' || true"
}